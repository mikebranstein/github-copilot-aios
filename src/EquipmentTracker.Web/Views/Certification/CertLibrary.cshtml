@model EquipmentTracker.Web.ViewModels.CertLibraryViewModel
@using EquipmentTracker.Web.Models

@{
    ViewData["Title"] = "Certification Library";
}

<h2>⚙️ Certification Library &amp; Equipment Requirements</h2>
<p class="text-muted">Manage the 15 pre-seeded cert types, add custom types, and assign cert requirements to equipment categories.</p>

@if (TempData["SuccessMessage"] != null) { <div class="alert alert-success">@TempData["SuccessMessage"]</div> }
@if (TempData["ErrorMessage"] != null)   { <div class="alert alert-danger">@TempData["ErrorMessage"]</div> }

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to Dashboard</a>
</div>

<div class="row">
    <!-- Cert Types -->
    <div class="col-md-7">
        <h4>Certification Types (@Model.CertTypes.Count)</h4>
        <table class="table table-sm table-bordered">
            <thead class="table-light">
                <tr><th>Name</th><th>Renewal (days)</th><th>Pre-seeded</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var ct in Model.CertTypes)
                {
                    <tr>
                        <td>@ct.Name<br/><small class="text-muted">@ct.Description</small></td>
                        <td>@(ct.RenewalPeriodDays == 0 ? "No expiry" : ct.RenewalPeriodDays.ToString())</td>
                        <td>@(ct.IsPreSeeded ? "✅" : "Custom")</td>
                        <td>
                            @if (!ct.IsPreSeeded)
                            {
                                <form asp-action="DeleteCertType" asp-route-id="@ct.Id" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Delete cert type \'@ct.Name\'?')">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <h5 class="mt-3">Add Custom Cert Type</h5>
        <form asp-action="AddCertType" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <div class="row g-2">
                <div class="col-md-5">
                    <input asp-for="NewCertType.Name" class="form-control" placeholder="Cert name" />
                    <span asp-validation-for="NewCertType.Name" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <input asp-for="NewCertType.Description" class="form-control" placeholder="Description" />
                </div>
                <div class="col-md-2">
                    <input asp-for="NewCertType.RenewalPeriodDays" class="form-control" placeholder="Days" />
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary w-100">Add</button>
                </div>
            </div>
        </form>
    </div>

    <!-- Equipment-Category Requirements -->
    <div class="col-md-5">
        <h4>Equipment-Category Requirements</h4>
        @if (!Model.Requirements.Any())
        {
            <div class="alert alert-info">No requirements configured. Add one below to enable cert enforcement for an equipment category.</div>
        }
        else
        {
            <table class="table table-sm table-bordered">
                <thead class="table-light">
                    <tr><th>Category</th><th>Required Cert</th><th>Active</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var req in Model.Requirements)
                    {
                        var certName = Model.AllCertTypesForDropdown.FirstOrDefault(c => c.Id == req.CertTypeId)?.Name ?? $"#{req.CertTypeId}";
                        <tr class="@(req.IsActive ? "" : "text-muted")">
                            <td>@req.EquipmentCategory</td>
                            <td>@certName</td>
                            <td>@(req.IsActive ? "✅" : "⏸️")</td>
                            <td>
                                @if (req.IsActive)
                                {
                                    <form asp-action="RemoveRequirement" asp-route-id="@req.Id" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger">Remove</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <h5 class="mt-3">Assign Requirement</h5>
        <form asp-action="AssignRequirement" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-2">
                <input asp-for="NewRequirement.EquipmentCategory" class="form-control"
                       placeholder="Equipment category (e.g. Forklift)" />
                <span asp-validation-for="NewRequirement.EquipmentCategory" class="text-danger"></span>
            </div>
            <div class="mb-2">
                <select asp-for="NewRequirement.CertTypeId" asp-items="Model.CertTypeSelectList"
                        class="form-select">
                    <option value="0">— Select cert type —</option>
                </select>
                <span asp-validation-for="NewRequirement.CertTypeId" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Assign</button>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
