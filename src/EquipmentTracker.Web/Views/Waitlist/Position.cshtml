@using EquipmentTracker.Web.Models
@{
    ViewData["Title"] = "Queue Position";
    var entry = ViewBag.Entry as WaitlistEntry;
    var item = ViewBag.Item as EquipmentItem;
    var position = ViewBag.Position is int p ? p : 0;
    var eta = ViewBag.Eta as string ?? "ETA unavailable";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h4 mb-3">@item?.Name waitlist</h2>
                <div class="row g-3 mb-3">
                    <div class="col-sm-4">
                        <div class="border rounded p-3 text-center">
                            <div class="text-muted small">Position</div>
                            <div class="display-6">#@position</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="border rounded p-3 text-center">
                            <div class="text-muted small">Tier</div>
                            <div class="fw-semibold">@entry?.Tier</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="border rounded p-3 text-center">
                            <div class="text-muted small">Status</div>
                            <div class="fw-semibold">@entry?.Status</div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info mb-3">
                    <strong>Estimated wait:</strong> @eta
                </div>

                @if (entry?.Status == WaitlistStatus.Reserved && entry.ConfirmationDeadlineUtc.HasValue)
                {
                    <div class="alert alert-success">
                        Reserved for you until <strong>@entry.ConfirmationDeadlineUtc.Value.ToString("g") UTC</strong>.
                        <a asp-action="Confirm" asp-route-entryId="@entry.Id" class="alert-link">Confirm now</a>.
                    </div>
                }

                <div class="d-flex flex-wrap gap-2">
                    @if (entry is not null && (entry.Status == WaitlistStatus.Waiting || entry.Status == WaitlistStatus.Reserved))
                    {
                        <form asp-action="Cancel" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="entryId" value="@entry.Id" />
                            <button type="submit" class="btn btn-outline-danger">Cancel entry</button>
                        </form>
                    }
                    <a asp-action="Alternatives" asp-route-equipmentItemId="@item?.Id" class="btn btn-outline-primary">View alternatives</a>
                    <a asp-controller="Equipment" asp-action="Index" class="btn btn-outline-secondary">Back to equipment</a>
                </div>
            </div>
        </div>
    </div>
</div>
