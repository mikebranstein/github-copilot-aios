@using System.Linq
@using EquipmentTracker.Web.Models
@{
    ViewData["Title"] = "Alternative Equipment";
    var item = ViewBag.Item as EquipmentItem;
    var alternatives = ViewBag.Alternatives as IEnumerable<EquipmentItem> ?? Enumerable.Empty<EquipmentItem>();
}

<div class="row">
    <div class="col-12">
        <h2 class="h4 mb-3">Alternatives for @item?.Name</h2>

        @if (!alternatives.Any())
        {
            <div class="alert alert-light border">No better alternatives are available right now.</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var alt in alternatives)
                {
                    <div class="col-md-6">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body">
                                <h3 class="h5">@alt.Name</h3>
                                <p class="text-muted mb-2">@alt.Category</p>
                                <span class="badge @(alt.IsAvailable ? "bg-success" : "bg-warning text-dark")">
                                    @(alt.IsAvailable ? "Available" : "Checked out")
                                </span>
                            </div>
                            <div class="card-footer bg-white border-0 pt-0">
                                <a asp-action="JoinQueue" asp-route-equipmentItemId="@alt.Id" class="btn btn-outline-primary btn-sm">Join queue</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="mt-3">
            <a asp-controller="Equipment" asp-action="Index" class="btn btn-outline-secondary">Back to equipment</a>
        </div>
    </div>
</div>
