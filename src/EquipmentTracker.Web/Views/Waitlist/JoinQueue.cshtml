@using EquipmentTracker.Web.Models
@{
    ViewData["Title"] = "Join Queue";
    var item = ViewBag.Item as EquipmentItem;
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h4 mb-3">Join waitlist</h2>
                <p class="text-muted">Request access to <strong>@item?.Name</strong>.</p>

                <form asp-action="JoinQueue" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="equipmentItemId" value="@item?.Id" />

                    <div class="mb-3">
                        <label class="form-label d-block">Priority tier</label>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="tier" id="tierStandard" value="Standard" checked />
                            <label class="form-check-label" for="tierStandard">Standard</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="tier" id="tierUrgent" value="Urgent" />
                            <label class="form-check-label" for="tierUrgent">Urgent</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Join queue</button>
                        <a asp-controller="Equipment" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
