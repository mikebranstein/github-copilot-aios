@using System.Linq
@using EquipmentTracker.Web.Models
@{
    ViewData["Title"] = "Queue Detail";
    var item = ViewBag.Item as EquipmentItem;
    var queue = ViewBag.Queue as List<WaitlistEntry> ?? new List<WaitlistEntry>();
    var history = ViewBag.History as List<WaitlistEntry> ?? new List<WaitlistEntry>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="h4 mb-1">@item?.Name queue</h2>
        <p class="text-muted mb-0">Manage priority, removals, and history.</p>
    </div>
    <a asp-action="AuditLog" asp-route-equipmentItemId="@item?.Id" class="btn btn-outline-secondary">Audit log</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h3 class="h5 mb-3">Active queue</h3>
        @if (!queue.Any())
        {
            <div class="alert alert-light border mb-0">No active entries.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Position</th>
                            <th>Borrower</th>
                            <th>Tier</th>
                            <th>Status</th>
                            <th>Joined</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in queue)
                        {
                            <tr>
                                <td>#@entry.QueuePosition</td>
                                <td>@entry.BorrowerName</td>
                                <td>@entry.Tier</td>
                                <td>@entry.Status</td>
                                <td>@entry.JoinedAtUtc.ToString("g") UTC</td>
                                <td>
                                    <div class="d-flex flex-column gap-2">
                                        <form asp-action="SetPosition" method="post" class="row g-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="entryId" value="@entry.Id" />
                                            <div class="col-auto">
                                                <input type="number" name="newPosition" min="1" value="@entry.QueuePosition" class="form-control form-control-sm" />
                                            </div>
                                            <div class="col">
                                                <input type="text" name="reason" class="form-control form-control-sm" placeholder="Reason" required />
                                            </div>
                                            <div class="col-auto">
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Set</button>
                                            </div>
                                        </form>

                                        <div class="d-flex gap-2">
                                            <form asp-action="RemoveEntry" method="post" class="d-flex gap-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="entryId" value="@entry.Id" />
                                                <input type="text" name="reason" class="form-control form-control-sm" placeholder="Removal reason" required />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                            </form>

                                            @if (entry.Status == WaitlistStatus.Waiting && entry.Tier != WaitlistTier.Urgent)
                                            {
                                                <form asp-action="MarkUrgent" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="entryId" value="@entry.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-warning">Mark urgent</button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h3 class="h5 mb-3">History</h3>
        @if (!history.Any())
        {
            <div class="alert alert-light border mb-0">No historical entries yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Borrower</th>
                            <th>Status</th>
                            <th>Exited</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in history)
                        {
                            <tr>
                                <td>@entry.BorrowerName</td>
                                <td>@entry.Status</td>
                                <td>@entry.ExitedAtUtc?.ToString("g") UTC</td>
                                <td>@(entry.ExitReason ?? entry.OverrideReason ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
