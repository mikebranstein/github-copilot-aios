@model EquipmentTracker.Web.ViewModels.RentalCostEntryViewModel

@{
    ViewData["Title"] = "Add Rental Cost Entry";
}

<div class="container mt-4">
    <h2>Add Rental Cost Entry</h2>
    <p class="text-muted">
        Enter rental costs manually for an asset category.
        (Automated invoice ingestion is coming in a future update.)
    </p>

    <form asp-action="AddRentalCost" method="post" class="mt-3" style="max-width: 500px;">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="mb-3">
            <label asp-for="AssetCategory" class="form-label"></label>
            <input asp-for="AssetCategory" class="form-control" placeholder="e.g. Excavator" />
            <span asp-validation-for="AssetCategory" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PeriodStart" class="form-label"></label>
            <input asp-for="PeriodStart" class="form-control" type="date" />
            <span asp-validation-for="PeriodStart" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PeriodEnd" class="form-label"></label>
            <input asp-for="PeriodEnd" class="form-control" type="date" />
            <span asp-validation-for="PeriodEnd" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CostAmount" class="form-label"></label>
            <input asp-for="CostAmount" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="CostAmount" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Save Entry</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</div>
