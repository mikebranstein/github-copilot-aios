@model EquipmentTracker.Web.ViewModels.MobileReturnConfirmViewModel
@{
    ViewData["Title"] = "Return Equipment";
    Layout = "_MobileLayout";
}

<div class="mobile-container">
    <h2 class="mobile-heading">Return Equipment</h2>
    <h3 class="item-name">@Model.Item.Name</h3>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-warning" role="alert">
            @Model.ErrorMessage
        </div>
    }

    @if (Model.Item.IsAvailable)
    {
        <p>This item is already available &mdash; there is nothing to return.</p>
        <a href="/mobile/return/scan" class="btn btn-secondary">Back to Scan</a>
    }
    else
    {
        <form method="post" action="/mobile/return/confirm" id="returnForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="itemId" value="@Model.Item.Id" />
            @if (Model.ActiveRecord != null)
            {
                <input type="hidden" name="checkoutRecordId" value="@Model.ActiveRecord.Id" />
            }

            @* AC1: Mandatory condition grade selection *@
            <div class="form-section">
                <label class="form-label required-label">Condition at Return <span class="required-star">*</span></label>
                <p class="form-hint">Select the condition grade before completing the return.</p>
                <div class="btn-group-grade" role="group" aria-label="Condition grade">
                    @foreach (var grade in new[] { "Good", "Worn", "Damaged", "Lost" })
                    {
                        var cssClass = grade == "Good" ? "btn-grade-good"
                                     : grade == "Worn" ? "btn-grade-worn"
                                     : grade == "Damaged" ? "btn-grade-damaged"
                                     : "btn-grade-lost";
                        var isSelected = Model.SelectedConditionGrade == grade;
                        <label class="btn-grade @cssClass @(isSelected ? "active" : "")" for="grade-@grade">
                            <input type="radio" name="conditionGrade" id="grade-@grade"
                                   value="@grade" @(isSelected ? "checked" : "") required>
                            @grade
                        </label>
                    }
                </div>
            </div>

            @* AC2: Photo capture for Damaged/Worn returns *@
            @if (Model.PhotoCaptureEnabled)
            {
                <div class="form-section photo-section" id="photoSection" style="display:none;">
                    <label class="form-label">Condition Photo (recommended for Damaged/Worn)</label>
                    <button type="button" class="btn btn-outline-secondary" id="capturePhotoBtn">
                        📷 Capture Photo
                    </button>
                    <div id="photoPreview" style="display:none;">
                        <img id="capturedPhoto" src="" alt="Captured photo" class="photo-preview-img" />
                        <input type="hidden" name="photoData" id="photoDataInput" />
                    </div>
                </div>
            }

            @if (Model.ConditionCaptureRequired)
            {
                <div class="form-section">
                    <label class="form-label required-label" for="returnConditionNote">Condition Note <span class="required-star">*</span></label>
                    <textarea name="returnConditionNote" id="returnConditionNote"
                              class="form-control" rows="3" maxlength="500"
                              placeholder="Describe the condition...">@Model.ActiveRecord?.ReturnConditionNote</textarea>
                </div>
            }
            else
            {
                <div class="form-section">
                    <label class="form-label" for="returnConditionNote">Condition Note (optional)</label>
                    <textarea name="returnConditionNote" id="returnConditionNote"
                              class="form-control" rows="2" maxlength="500"
                              placeholder="Optional notes...">@Model.ActiveRecord?.ReturnConditionNote</textarea>
                </div>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-return" id="submitBtn" disabled>
                    Confirm Return
                </button>
                <a href="/mobile/return/scan" class="btn btn-secondary">Cancel</a>
            </div>
        </form>

        <script>
        // Enable submit button only when a grade is selected (AC1 client-side gate)
        const radios = document.querySelectorAll('input[name="conditionGrade"]');
        const submitBtn = document.getElementById('submitBtn');
        const photoSection = document.getElementById('photoSection');

        function onGradeChange() {
            const selected = document.querySelector('input[name="conditionGrade"]:checked');
            if (selected) {
                submitBtn.disabled = false;
                // Show photo section for Damaged/Worn
                if (photoSection) {
                    photoSection.style.display =
                        (selected.value === 'Damaged' || selected.value === 'Worn') ? 'block' : 'none';
                }
            }
        }
        radios.forEach(r => r.addEventListener('change', onGradeChange));
        // Initialise from pre-selected grade
        onGradeChange();
        </script>
    }
</div>