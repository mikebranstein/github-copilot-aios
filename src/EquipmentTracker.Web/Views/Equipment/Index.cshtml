@model EquipmentTracker.Web.ViewModels.EquipmentListViewModel

@{
    ViewData["Title"] = "Equipment";
}

<h2>Team Equipment</h2>

<p class="text-muted">Available items: <strong>@Model.AvailableCount</strong></p>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mb-3 d-flex flex-wrap gap-2">
    <a asp-action="Create" class="btn btn-primary">+ Add Equipment</a>
    <a asp-controller="Availability" asp-action="Index" class="btn btn-outline-secondary">Availability View</a>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Site</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Category</td>
                    <td>@(item.SiteName ?? "Unassigned")</td>
                    <td>
                        <span class="badge @item.StatusBadgeClass">@item.StatusDisplay</span>
                        @if (item.IsOverdue)
                        {
                            <span class="badge bg-danger ms-1"
                                  data-bs-toggle="tooltip"
                                  data-bs-placement="top"
                                  title="@item.BorrowerName — @item.DaysCheckedOut day@(item.DaysCheckedOut == 1 ? "" : "s")">
                                Overdue
                            </span>
                        }
                    </td>
                    <td>
                        @if (item.IsAvailable)
                        {
                            <a asp-action="Checkout" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Check Out</a>
                        }
                        else
                        {
                            <form asp-action="Return" asp-route-id="@item.Id" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Return</button>
                            </form>
                        }
                        <a asp-action="History" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info ms-1">History</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipEls = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipEls.forEach(function (el) { new bootstrap.Tooltip(el); });
        });
    </script>
}
