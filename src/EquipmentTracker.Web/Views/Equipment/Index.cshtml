@model EquipmentTracker.Web.ViewModels.EquipmentListViewModel

@{
    ViewData["Title"] = "Equipment";
}

<h2>Team Equipment</h2>

<p class="text-muted">Available items: <strong>@Model.AvailableCount</strong></p>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">+ Add Equipment</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Category</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Category</td>
                <td>
                    @if (item.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Checked Out</span>
                    }
                </td>
                <td>
                    @if (item.IsAvailable)
                    {
                        <a asp-action="Checkout" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Check Out</a>
                    }
                    else
                    {
                        <form asp-action="Return" asp-route-id="@item.Id" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Return</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
