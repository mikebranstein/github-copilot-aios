@model EquipmentTracker.Web.ViewModels.EquipmentListViewModel

@{
    ViewData["Title"] = "Equipment";
}

<h2>Team Equipment</h2>

<p class="text-muted">Available items: <strong>@Model.AvailableCount</strong></p>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">+ Add Equipment</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Category</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Category</td>
                <td>
                    @if (item.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Checked Out</span>

                        @if (item.IsOverdue)
                        {
                            <span class="badge bg-danger ms-1"
                                  data-bs-toggle="tooltip"
                                  data-bs-placement="top"
                                  title="@item.BorrowerName — @item.DaysCheckedOut day@(item.DaysCheckedOut == 1 ? "" : "s")">
                                Overdue
                            </span>
                        }
                    }
                </td>
                <td>
                    @if (item.IsAvailable)
                    {
                        <a asp-action="Checkout" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Check Out</a>
                    }
                    else
                    {
                        <form asp-action="Return" asp-route-id="@item.Id" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Return</button>
                        </form>
                    }
                    <a asp-action="History" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info ms-1">History</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        // Initialise Bootstrap tooltips on the overdue badges
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipEls = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipEls.forEach(function (el) { new bootstrap.Tooltip(el); });
        });
    </script>
}
