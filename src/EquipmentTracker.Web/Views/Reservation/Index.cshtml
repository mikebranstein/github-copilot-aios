@model EquipmentTracker.Web.ViewModels.ReservationListViewModel
@using EquipmentTracker.Web.Models
@{
    ViewData["Title"] = "My Reservations";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>My Reservations</h1>
        <div>
            <a asp-action="Create" class="btn btn-primary me-2">+ New Reservation</a>
            <a asp-action="Calendar" class="btn btn-outline-secondary me-2">📅 Calendar</a>
            <a asp-action="CrossSite" class="btn btn-outline-info">🗺 Cross-Site View</a>
        </div>
    </div>

    @if (Model.Notifications.Any(n => !n.IsRead))
    {
        <div class="alert alert-warning" role="alert">
            <strong>Notifications:</strong> You have @Model.Notifications.Count(n => !n.IsRead) unread reservation notification(s).
            <ul class="mb-0 mt-2">
                @foreach (var notification in Model.Notifications.Where(n => !n.IsRead).Take(5))
                {
                    <li>
                        @notification.Message
                        @if (!string.IsNullOrEmpty(notification.ActionUrl))
                        {
                            <a href="@notification.ActionUrl" class="ms-2">View</a>
                        }
                        <form asp-action="MarkNotificationRead" method="post" class="d-inline ms-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="notificationId" value="@notification.Id" />
                            <button type="submit" class="btn btn-sm btn-link p-0">Dismiss</button>
                        </form>
                    </li>
                }
            </ul>
        </div>
    }

    @if (!Model.MyReservations.Any())
    {
        <div class="alert alert-info">
            No reservations found. <a asp-action="Create">Create your first reservation</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover" aria-label="My Reservations">
                <thead class="table-dark">
                    <tr>
                        <th>Project</th>
                        <th>Equipment</th>
                        <th>Site</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reservation in Model.MyReservations)
                    {
                        <tr>
                            <td>@reservation.ProjectName</td>
                            <td>@reservation.EquipmentName</td>
                            <td>@reservation.SiteName</td>
                            <td>@reservation.StartDate.ToString("MMM d, yyyy")</td>
                            <td>@reservation.EndDate.ToString("MMM d, yyyy")</td>
                            <td>
                                @if (reservation.Status == ReservationStatus.Active)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else if (reservation.Status == ReservationStatus.Cancelled)
                                {
                                    <span class="badge bg-secondary">Cancelled</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Overridden</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@reservation.Id" class="btn btn-sm btn-outline-primary">View</a>
                                @if (reservation.Status == ReservationStatus.Active)
                                {
                                    <a asp-action="Edit" asp-route-id="@reservation.Id" class="btn btn-sm btn-outline-secondary ms-1">Edit</a>
                                    <form asp-action="Cancel" method="post" class="d-inline ms-1"
                                          onsubmit="return confirm('Cancel this reservation? This cannot be undone.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@reservation.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
