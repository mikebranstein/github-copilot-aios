@model EquipmentTracker.Web.ViewModels.EditReservationViewModel
@{
    ViewData["Title"] = "Edit Reservation";
}

<div class="container">
    <h1>Edit Reservation</h1>
    <p class="text-muted">Update the date range or equipment asset. Past start dates are not allowed.</p>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReservationId" />

        <div class="row">
            <div class="col-md-6">
                <div class="card mb-3">
                    <div class="card-header fw-bold">Equipment Asset</div>
                    <div class="card-body">
                        <label asp-for="EquipmentId" class="form-label">Select Equipment</label>
                        <select asp-for="EquipmentId" class="form-select" required>
                            @foreach (var item in Model.AvailableEquipment)
                            {
                                <option value="@item.Id">@item.Name (@item.Category) — @item.SiteName</option>
                            }
                        </select>
                        <span asp-validation-for="EquipmentId" class="text-danger"></span>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header fw-bold">Date Range</div>
                    <div class="card-body">
                        <div class="mb-2">
                            <label asp-for="StartDate" class="form-label">Start Date</label>
                            <input asp-for="StartDate" type="date" class="form-control"
                                   min="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                        <div class="mb-2">
                            <label asp-for="EndDate" class="form-label">End Date</label>
                            <input asp-for="EndDate" type="date" class="form-control"
                                   min="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Details" asp-route-id="@Model.ReservationId" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
