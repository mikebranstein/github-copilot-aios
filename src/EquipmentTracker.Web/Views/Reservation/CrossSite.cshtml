@model EquipmentTracker.Web.ViewModels.CrossSiteViewModel
@using EquipmentTracker.Web.Services
@{
    ViewData["Title"] = "Cross-Site Equipment Availability";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h1>🗺 Cross-Site Availability</h1>
        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-primary btn-sm">+ New Reservation</a>
            <a asp-action="Calendar" class="btn btn-outline-secondary btn-sm">📅 Calendar View</a>
        </div>
    </div>
    <p class="text-muted">
        Unified equipment availability across all sites for the next
        <strong>@Model.WindowDays days</strong>
        (@Model.From.ToString("MMM d") – @Model.To.ToString("MMM d, yyyy")).
    </p>

    <!-- Filters -->
    <form asp-action="CrossSite" method="get" class="row g-2 mb-3">
        <div class="col-md-3">
            <label class="form-label">Site</label>
            <select name="siteId" class="form-select form-select-sm">
                <option value="">All Sites</option>
                @foreach (var site in Model.AvailableSites)
                {
                    if (Model.FilterSiteId == site.SiteId)
                    {
                        <option value="@site.SiteId" selected>@site.SiteName</option>
                    }
                    else
                    {
                        <option value="@site.SiteId">@site.SiteName</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Window (days)</label>
            <select name="windowDays" class="form-select form-select-sm">
                @foreach (var w in new[] { 7, 14, 30 })
                {
                    if (Model.WindowDays == w)
                    {
                        <option value="@w" selected>@w days</option>
                    }
                    else
                    {
                        <option value="@w">@w days</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-outline-primary btn-sm w-100">Apply</button>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <a asp-action="CrossSite" class="btn btn-outline-secondary btn-sm w-100">Reset</a>
        </div>
    </form>

    @if (!Model.Summaries.Any())
    {
        <div class="alert alert-info">No equipment assets found for the selected filters.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover" aria-label="Cross-Site Availability">
                <thead class="table-dark">
                    <tr>
                        <th>Site</th>
                        <th>Equipment</th>
                        <th>Category</th>
                        <th>Availability Status</th>
                        <th>Booked Days / Total</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        string? lastSite = null;
                    }
                    @foreach (var summary in Model.Summaries)
                    {
                        <tr>
                            <td>
                                @if (summary.SiteName != lastSite)
                                {
                                    lastSite = summary.SiteName;
                                    <strong>@summary.SiteName</strong>
                                }
                            </td>
                            <td>@summary.EquipmentName</td>
                            <td>@summary.Category</td>
                            <td>
                                @switch (summary.Status)
                                {
                                    case AvailabilityStatus.Available:
                                        <span class="badge bg-success">Available</span>
                                        break;
                                    case AvailabilityStatus.PartiallyBooked:
                                        <span class="badge bg-warning text-dark">Partially Booked</span>
                                        break;
                                    case AvailabilityStatus.FullyBooked:
                                        <span class="badge bg-danger">Fully Booked</span>
                                        break;
                                }
                            </td>
                            <td>
                                @summary.BookedDayCount / @summary.TotalDayCount
                                <div class="progress" style="height:6px;">
                                    <div class="progress-bar @(summary.Status == AvailabilityStatus.FullyBooked ? "bg-danger" : summary.Status == AvailabilityStatus.PartiallyBooked ? "bg-warning" : "bg-success")"
                                         role="progressbar"
                                         style="width: @(summary.TotalDayCount > 0 ? (summary.BookedDayCount * 100 / summary.TotalDayCount) : 0)%">
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (summary.Status != AvailabilityStatus.FullyBooked)
                                {
                                    <a asp-action="Create" asp-route-equipmentId="@summary.EquipmentId"
                                       class="btn btn-sm btn-outline-primary">Reserve</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
