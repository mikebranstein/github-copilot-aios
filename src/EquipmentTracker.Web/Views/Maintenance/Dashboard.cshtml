@model EquipmentTracker.Web.ViewModels.ServiceDueDashboardViewModel
@using EquipmentTracker.Web.Models

@{
    ViewData["Title"] = "Service Due Dashboard";
}

<div class="container mt-4">
    <h1>🔧 Service Due Dashboard</h1>
    <p class="text-muted">Fleet-wide maintenance status. Phase 1 — rule-based scheduling.</p>

    @* Status Summary Bands *@
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-danger text-center">
                <div class="card-body">
                    <h2 class="text-danger">@Model.OverdueCount</h2>
                    <p class="card-text fw-bold">Overdue</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning text-center">
                <div class="card-body">
                    <h2 class="text-warning">@Model.CautionCount</h2>
                    <p class="card-text fw-bold">Caution</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success text-center">
                <div class="card-body">
                    <h2 class="text-success">@Model.InRangeCount</h2>
                    <p class="card-text fw-bold">In Range</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-secondary text-center">
                <div class="card-body">
                    <h2 class="text-secondary">@Model.NoDataCount</h2>
                    <p class="card-text fw-bold">No Data</p>
                </div>
            </div>
        </div>
    </div>

    @* Filter Controls *@
    <form method="get" class="row g-3 mb-3">
        <div class="col-md-3">
            <label class="form-label">Status Band</label>
            <select name="filterBand" class="form-select">
                <option value="">All</option>
                <option value="Overdue" selected="@(Model.FilterBand == "Overdue")">Overdue</option>
                <option value="Caution" selected="@(Model.FilterBand == "Caution")">Caution</option>
                <option value="InRange" selected="@(Model.FilterBand == "InRange")">In Range</option>
                <option value="NoData" selected="@(Model.FilterBand == "NoData")">No Data</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Equipment Type</label>
            <input type="text" name="filterCategory" class="form-control" placeholder="e.g. Crane" value="@Model.FilterCategory" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Sort By</label>
            <select name="sortBy" class="form-select">
                <option value="band" selected="@(Model.SortBy == "band" || Model.SortBy == null)">Status Band</option>
                <option value="hours" selected="@(Model.SortBy == "hours")">Hours Remaining</option>
                <option value="name" selected="@(Model.SortBy == "name")">Asset Name</option>
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button type="submit" class="btn btn-primary me-2">Filter</button>
            <a href="@Url.Action("Dashboard")" class="btn btn-outline-secondary">Reset</a>
        </div>
    </form>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @* Assets Table *@
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Status</th>
                <th>Asset Name</th>
                <th>Category</th>
                <th>Hours Used</th>
                <th>Hours Remaining</th>
                <th>Projected Service Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.FilteredStatuses)
            {
                var rowClass = s.Band switch
                {
                    MaintenanceBand.Overdue => "table-danger",
                    MaintenanceBand.Caution => "table-warning",
                    MaintenanceBand.InRange => "table-success",
                    _ => ""
                };
                var badgeClass = s.Band switch
                {
                    MaintenanceBand.Overdue => "bg-danger",
                    MaintenanceBand.Caution => "bg-warning text-dark",
                    MaintenanceBand.InRange => "bg-success",
                    _ => "bg-secondary"
                };
                <tr class="@rowClass">
                    <td>
                        <span class="badge @badgeClass">
                            @(s.Band switch {
                                MaintenanceBand.Overdue => "Overdue",
                                MaintenanceBand.Caution => "Caution",
                                MaintenanceBand.InRange => "In Range",
                                _ => "No Data"
                            })
                        </span>
                        @if (s.IsSnoozed) { <span class="badge bg-secondary ms-1">Snoozed</span> }
                    </td>
                    <td>@s.AssetName</td>
                    <td>@s.Category</td>
                    <td>
                        @if (s.HasOpenCheckout)
                        {
                            <span title="Open checkout detected — hours may be incomplete">@s.OperatingHours.ToString("F1") hrs ⚠️</span>
                        }
                        else if (s.Band == MaintenanceBand.NoData && !s.HasIntervalConfigured)
                        {
                            <span class="text-muted">No interval configured</span>
                        }
                        else
                        {
                            <span>@s.OperatingHours.ToString("F1") hrs</span>
                        }
                    </td>
                    <td>
                        @if (s.HoursRemaining.HasValue)
                        {
                            <span>@s.HoursRemaining.Value.ToString("F1") hrs</span>
                        }
                        else if (s.DaysRemaining.HasValue)
                        {
                            <span>@s.DaysRemaining.Value days</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        @if (s.ProjectedServiceDate.HasValue)
                        {
                            <span>@s.ProjectedServiceDate.Value.ToString("MMM d, yyyy")</span>
                        }
                        else if (s.NextDueDate.HasValue)
                        {
                            <span>@s.NextDueDate.Value.ToString("MMM d, yyyy")</span>
                        }
                        else if (s.Band == MaintenanceBand.NoData)
                        {
                            <span class="text-muted">Insufficient data</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        <a href="@Url.Action("AssetDetail", new { id = s.AssetId })" class="btn btn-sm btn-outline-primary">Details</a>
                        @if (s.Band == MaintenanceBand.Caution || s.Band == MaintenanceBand.Overdue)
                        {
                            <form method="post" action="@Url.Action("SnoozeAlert")" class="d-inline ms-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="assetId" value="@s.AssetId" />
                                <input type="hidden" name="days" value="14" />
                                <button type="submit" class="btn btn-sm btn-outline-warning">Snooze 14d</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a href="@Url.Action("ServiceIntervals")" class="btn btn-outline-secondary me-2">⚙️ Configure Intervals</a>
        <a href="@Url.Action("GateMetric")" class="btn btn-outline-info me-2">📊 Phase 2 Gate Metric</a>
        <a href="@Url.Action("DowntimeCostCalculator")" class="btn btn-outline-success">💰 Downtime Cost Calculator</a>
    </div>
</div>
