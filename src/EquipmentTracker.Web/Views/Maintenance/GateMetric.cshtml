@model EquipmentTracker.Web.ViewModels.MaintenanceGateMetricViewModel

@{
    ViewData["Title"] = "Phase 2 ML Gate Metric";
}

<div class="container mt-4">
    <h1>📊 Phase 2 ML Gate Metric</h1>
    <p class="text-muted">
        Track the Maintenance Log Completion Rate — the gate criterion for unlocking Phase 2 ML features.
    </p>

    <div class="card @(Model.GateMet ? "border-success" : "border-warning") mb-4">
        <div class="card-body text-center">
            <h2 class="@(Model.GateMet ? "text-success" : "text-warning")">
                @Model.CompletionRatePercent.ToString("F1")%
            </h2>
            <p class="fs-5 fw-bold">Maintenance Log Completion Rate</p>
            <p class="text-muted">
                % of enrolled assets with at least one logged maintenance event in the past 90 days.
            </p>

            @* Progress Bar *@
            <div class="progress mb-3" style="height: 24px;">
                <div class="progress-bar @(Model.GateMet ? "bg-success" : "bg-warning")"
                     role="progressbar"
                     style="width: @Math.Min(Model.CompletionRatePercent, 100)%"
                     aria-valuenow="@Model.CompletionRatePercent"
                     aria-valuemin="0"
                     aria-valuemax="100">
                    @Model.CompletionRatePercent.ToString("F1")%
                </div>
            </div>

            @* Gate Indicator *@
            <div class="alert @(Model.GateMet ? "alert-success" : "alert-warning")">
                <strong>@Model.GateStatusMessage</strong>
            </div>

            <p class="text-muted small">
                Phase 2 ML capabilities (survival analysis, failure scoring, probabilistic prediction)
                are explicitly deferred until the 40% gate is met and verified.
                This is a hard product gate — Phase 2 must not be promoted in-product until this threshold is reached.
            </p>
        </div>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Dashboard")" class="btn btn-outline-secondary">← Back to Dashboard</a>
    </div>
</div>
