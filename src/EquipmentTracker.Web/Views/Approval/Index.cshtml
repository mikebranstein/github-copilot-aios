@model IReadOnlyList<EquipmentTracker.Web.Controllers.ApprovalQueueItem>
@{
    ViewData["Title"] = "Approval Queue";
    Layout = "_Layout";
}

<div class="container py-3">
    <h3 class="mb-3">🔔 Coordinator Approval Queue</h3>

    @if (TempData["SuccessMessage"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }
    @if (TempData["ErrorMessage"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">No pending approval requests. ✅</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Requester</th>
                        <th>Equipment</th>
                        <th>Category</th>
                        <th>Requested At (UTC)</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Request.Id</td>
                            <td>@item.RequesterName</td>
                            <td><strong>@item.ItemName</strong></td>
                            <td>@item.ItemCategory</td>
                            <td>@item.Request.RequestedAtUtc.ToString("g") UTC</td>
                            <td>
                                <a href="/coordinator/approvals/@item.Request.Id" class="btn btn-sm btn-outline-primary me-1">Details</a>
                                <form method="post" action="/coordinator/approvals/@item.Request.Id/approve" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-success me-1">✅ Approve</button>
                                </form>
                                <button type="button" class="btn btn-sm btn-danger"
                                        data-bs-toggle="modal" data-bs-target="#denyModal-@item.Request.Id">
                                    ❌ Deny
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Deny modals *@
        @foreach (var item in Model)
        {
            <div class="modal fade" id="denyModal-@item.Request.Id" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Deny Checkout — @item.ItemName</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <form method="post" action="/coordinator/approvals/@item.Request.Id/deny">
                            @Html.AntiForgeryToken()
                            <div class="modal-body">
                                <label for="reason-@item.Request.Id" class="form-label">Denial Reason (optional)</label>
                                <textarea id="reason-@item.Request.Id" name="reason" class="form-control" rows="3"
                                          placeholder="Explain why the checkout is denied..."></textarea>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-danger">Deny Checkout</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }

    <a href="/" class="btn btn-outline-secondary mt-3">← Back to Home</a>
</div>
