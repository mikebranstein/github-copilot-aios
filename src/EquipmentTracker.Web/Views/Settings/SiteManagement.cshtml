@model EquipmentTracker.Web.ViewModels.SiteManagementViewModel

@{
    ViewData["Title"] = "Site Management";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-10">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-4">
            <div>
                <h2 class="mb-1">Site Management</h2>
                <p class="text-muted mb-0">Create, rename, activate, or deactivate sites.</p>
            </div>
            <a asp-action="Notifications" class="btn btn-outline-secondary">Back to Settings</a>
        </div>

        @if (TempData["SiteSuccess"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }

        @if (TempData["SiteError"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }

        <div class="card mb-4">
            <div class="card-body">
                <h3 class="h5">Create Site</h3>
                <form asp-action="CreateSite" method="post" class="row g-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <div class="col-12 col-md-8">
                        <label for="Name" class="form-label">Site Name</label>
                        <input id="Name" name="Name" class="form-control" maxlength="100" />
                    </div>
                    <div class="col-12 col-md-4 d-grid">
                        <button type="submit" class="btn btn-primary">Create Site</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="row g-3">
            @if (Model.Sites.Count == 0)
            {
                <div class="col-12">
                    <div class="alert alert-info mb-0">No sites created yet.</div>
                </div>
            }
            else
            {
                @foreach (var site in Model.Sites.OrderBy(s => s.Name))
                {
                    <div class="col-12">
                        <div class="card">
                            <div class="card-body">
                                <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                                    <div>
                                        <h3 class="h5 mb-1">@site.Name</h3>
                                        <span class="badge @(site.IsActive ? "bg-success" : "bg-secondary")">
                                            @(site.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </div>
                                    <div class="flex-grow-1">
                                        <form asp-action="RenameSite" method="post" class="row g-2 align-items-end">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="SiteId" value="@site.Id" />
                                            <div class="col-12 col-md-7">
                                                <label class="form-label" for="rename-@site.Id">Rename Site</label>
                                                <input id="rename-@site.Id" name="NewName" value="@site.Name" class="form-control" maxlength="100" />
                                            </div>
                                            <div class="col-12 col-md-5 d-grid d-md-flex gap-2">
                                                <button type="submit" class="btn btn-outline-primary flex-fill">Save Name</button>
                                            </div>
                                        </form>
                                        <div class="mt-2 d-grid d-md-flex gap-2">
                                            @if (site.IsActive)
                                            {
                                                <form asp-action="DeactivateSite" method="post" class="d-grid">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="siteId" value="@site.Id" />
                                                    <button type="submit" class="btn btn-outline-danger">Deactivate</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="ActivateSite" method="post" class="d-grid">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="siteId" value="@site.Id" />
                                                    <button type="submit" class="btn btn-outline-success">Activate</button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
