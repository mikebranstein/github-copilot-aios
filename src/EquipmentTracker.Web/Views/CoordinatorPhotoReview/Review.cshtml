@model EquipmentTracker.Web.ViewModels.CoordinatorPhotoReviewViewModel
@{
    ViewData["Title"] = $"Review — {Model.ItemName}";
    Layout = "_Layout";
}

<div class="container py-3">
    <h4 class="mb-1">🔍 Photo Review</h4>
    <p class="text-muted small mb-3">
        <strong>@Model.ItemName</strong> — borrowed by @Model.BorrowerName<br />
        Checked out: @Model.CheckedOutAtUtc.ToString("g") UTC
        @if (Model.ReturnedAtUtc.HasValue)
        {
            <text> · Returned: @Model.ReturnedAtUtc.Value.ToString("g") UTC</text>
        }
    </p>

    @if (TempData["SuccessMessage"] is string msg)
    {
        <div class="alert alert-success">@msg</div>
    }

    <!-- Side-by-side photo comparison (AC-CR1) -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold">📸 Checkout Condition</div>
                <div class="card-body text-center">
                    @if (Model.HasCheckoutPhoto)
                    {
                        <!-- AC-CR2: Enlarge checkout photo command -->
                        @if (Model.EnlargeCheckoutPhotoCommand)
                        {
                            <a href="@Model.CheckoutPhotoUrl" target="_blank" title="Click to enlarge">
                                <img src="@Model.CheckoutPhotoUrl"
                                     class="img-fluid rounded"
                                     alt="Checkout condition photo"
                                     style="max-height:350px;" />
                            </a>
                            <p class="text-muted small mt-1">Click to enlarge</p>
                        }
                        else
                        {
                            <img src="@Model.CheckoutPhotoUrl" class="img-fluid rounded" alt="Checkout condition photo" />
                        }
                    }
                    else
                    {
                        <div class="text-muted py-5">No checkout photo available</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold">📸 Return Condition</div>
                <div class="card-body text-center">
                    @if (Model.HasReturnPhoto)
                    {
                        <!-- AC-CR2: Enlarge return photo command -->
                        @if (Model.EnlargeReturnPhotoCommand)
                        {
                            <a href="@Model.ReturnPhotoUrl" target="_blank" title="Click to enlarge">
                                <img src="@Model.ReturnPhotoUrl"
                                     class="img-fluid rounded"
                                     alt="Return condition photo"
                                     style="max-height:350px;" />
                            </a>
                            <p class="text-muted small mt-1">Click to enlarge</p>
                        }
                        else
                        {
                            <img src="@Model.ReturnPhotoUrl" class="img-fluid rounded" alt="Return condition photo" />
                        }
                    }
                    else
                    {
                        <div class="text-muted py-5">No return photo available</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Damage assessment form (AC-CR3) -->
    <div class="card">
        <div class="card-header fw-semibold">🏷 Set Damage Assessment</div>
        <div class="card-body">
            <form method="post" action="/coordinator/photo-review/set-damage-assessment">
                @Html.AntiForgeryToken()
                <input type="hidden" name="checkoutRecordId" value="@Model.CheckoutRecordId" />

                <div class="d-flex flex-wrap gap-2 mb-3">
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="assessment" id="no-damage"
                               value="NoDamage" @(Model.ConditionAssessment == "NoDamage" ? "checked" : "") />
                        <label class="form-check-label" for="no-damage">
                            <span class="badge bg-success">✅ No Damage</span>
                        </label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="assessment" id="minor-damage"
                               value="MinorDamage" @(Model.ConditionAssessment == "MinorDamage" ? "checked" : "") />
                        <label class="form-check-label" for="minor-damage">
                            <span class="badge bg-warning text-dark">⚠️ Minor Damage</span>
                        </label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="assessment" id="significant-damage"
                               value="SignificantDamage" @(Model.ConditionAssessment == "SignificantDamage" ? "checked" : "") />
                        <label class="form-check-label" for="significant-damage">
                            <span class="badge bg-danger">🚨 Significant Damage</span>
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary" style="min-height:48px;">
                    💾 Save Assessment
                </button>
            </form>
        </div>
    </div>

    <div class="mt-3">
        <a href="/coordinator/photo-review" class="btn btn-outline-secondary">← Back to list</a>
    </div>
</div>
