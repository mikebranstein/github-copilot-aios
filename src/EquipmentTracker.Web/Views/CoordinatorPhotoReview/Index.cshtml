@model IEnumerable<EquipmentTracker.Web.ViewModels.CoordinatorPhotoReviewViewModel>
@{
    ViewData["Title"] = "Photo Review — Returned Items";
    Layout = "_Layout";
}

<div class="container py-3">
    <h4 class="mb-3">🔍 Photo Review — Returned Equipment</h4>
    <p class="text-muted small">Compare checkout and return photos, then set a damage assessment for each item.</p>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No returned items awaiting photo review.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Item</th>
                        <th>Borrower</th>
                        <th>Returned</th>
                        <th>Photos</th>
                        <th>Assessment</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ItemName</td>
                            <td>@item.BorrowerName</td>
                            <td>@item.ReturnedAtUtc?.ToString("g") UTC</td>
                            <td>
                                @if (item.HasCheckoutPhoto)
                                {
                                    <span class="badge bg-success me-1">📸 Checkout</span>
                                }
                                @if (item.HasReturnPhoto)
                                {
                                    <span class="badge bg-primary">📸 Return</span>
                                }
                                @if (!item.HasCheckoutPhoto && !item.HasReturnPhoto)
                                {
                                    <span class="badge bg-secondary">No photos</span>
                                }
                            </td>
                            <td>
                                @{
                                    var badgeClass = item.ConditionAssessment switch
                                    {
                                        "NoDamage" => "bg-success",
                                        "MinorDamage" => "bg-warning text-dark",
                                        "SignificantDamage" => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@item.ConditionAssessment</span>
                            </td>
                            <td>
                                <a href="/coordinator/photo-review/review/@item.CheckoutRecordId"
                                   class="btn btn-sm btn-outline-primary">Review →</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
