@model EquipmentTracker.Web.ViewModels.NlCheckoutInputViewModel
@{
    ViewData["Title"] = "NL Checkout";
    Layout = "_Layout";
}

<div class="container-fluid px-2 py-3">
    <h4 class="mb-1">💬 Natural Language Checkout</h4>
    <p class="text-muted small mb-3">Type what you want to check out in plain English.</p>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <strong>⚠️</strong> @Model.ErrorMessage
            <hr class="my-1" />
            <a asp-controller="MobileCheckout" asp-action="Scan" class="btn btn-sm btn-outline-secondary mt-1">
                Use Standard Checkout
            </a>
        </div>
    }

    <form asp-action="Parse" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label for="utterance" class="form-label fw-semibold">What do you need?</label>
            <textarea id="utterance" name="utterance" class="form-control"
                      rows="3" style="font-size:1.15rem; min-height:80px;"
                      placeholder="e.g. Check out Drill #4 to me until Friday"
                      autocomplete="off" autocorrect="off" spellcheck="false">@Model.Utterance</textarea>
            <div class="form-text">
                Try: <em>"Check out Ladder 2 for 3 days"</em> or <em>"Checkout saw #1 until October 15"</em>
            </div>
        </div>
        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-primary btn-lg">
                🚀 Parse &amp; Continue
            </button>
            <a asp-controller="MobileCheckout" asp-action="Scan" class="btn btn-outline-secondary">
                Use Standard Checkout Instead
            </a>
        </div>
    </form>
</div>
