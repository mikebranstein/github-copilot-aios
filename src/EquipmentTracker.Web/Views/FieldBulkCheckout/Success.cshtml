@{
    ViewData["Title"] = "Bulk Checkout Complete";
    var batchId = ViewBag.BatchId as string;
    var successCount = ViewBag.SuccessCount;
    var failedCount = ViewBag.FailedCount;
    var borrowerName = ViewBag.BorrowerName as string;
}

<div class="text-center my-4">
    <h2 class="text-success">✓ Bulk Checkout Complete</h2>

    @if (!string.IsNullOrEmpty(borrowerName))
    {
        <p class="lead">Checked out to <strong>@borrowerName</strong></p>
    }

    <div class="row justify-content-center mt-3">
        <div class="col-auto">
            <div class="card border-success p-3 text-center" style="min-width:140px;">
                <h3 class="text-success">@successCount</h3>
                <small>Items Checked Out</small>
            </div>
        </div>
        @if (failedCount is int fc && fc > 0)
        {
            <div class="col-auto">
                <div class="card border-warning p-3 text-center" style="min-width:140px;">
                    <h3 class="text-warning">@failedCount</h3>
                    <small>Skipped / Failed</small>
                </div>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(batchId))
    {
        <p class="mt-3 text-muted small">Batch ID: <code>@batchId</code></p>
    }

    <div class="mt-4">
        <a asp-action="Scan" asp-controller="FieldBulkCheckout"
           class="btn btn-primary btn-lg" style="min-height:56px;min-width:200px;">
            &#43; New Bulk Checkout
        </a>
    </div>
</div>
