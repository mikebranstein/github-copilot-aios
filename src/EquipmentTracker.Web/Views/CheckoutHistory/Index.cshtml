@model EquipmentTracker.Web.ViewModels.CheckoutHistoryViewModel

@{
    ViewData["Title"] = "Checkout History";
}

<h2>Checkout History</h2>

@* ── Filter form ──────────────────────────────────────────────────────────── *@
<form method="get" asp-action="Index" asp-controller="CheckoutHistory" class="mb-3 d-flex gap-2">
    <input type="text"
           name="filter"
           value="@Model.Filter"
           class="form-control"
           style="max-width: 300px;"
           placeholder="Filter by holder name…" />
    <button type="submit" class="btn btn-outline-secondary">Filter</button>
    @if (!string.IsNullOrWhiteSpace(Model.Filter))
    {
        <a asp-action="Index" asp-controller="CheckoutHistory" class="btn btn-outline-danger">Clear</a>
    }
</form>

@* ── Empty states ─────────────────────────────────────────────────────────── *@
@if (Model.TotalMatchingCount == 0 && string.IsNullOrWhiteSpace(Model.Filter))
{
    <p class="text-muted">No checkout history yet</p>
}
else if (Model.TotalMatchingCount == 0)
{
    <p class="text-muted">No checkout history matches '@Model.Filter'</p>
}
else
{
    @* ── Table ────────────────────────────────────────────────────────────── *@
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Item</th>
                <th>Holder</th>
                <th>Checked Out</th>
                <th>Returned</th>
                <th>Duration</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@row.ItemName</td>
                    <td>@row.HolderName</td>
                    <td>@row.CheckedOutAtUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                    @if (row.IsOpen)
                    {
                        <td><strong class="text-warning">@row.ReturnDateDisplay</strong></td>
                    }
                    else
                    {
                        <td>@row.ReturnDateDisplay</td>
                    }
                    <td>@row.DurationDisplay</td>
                </tr>
            }
        </tbody>
    </table>

    @* ── Pagination ───────────────────────────────────────────────────────── *@
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Checkout history pagination">
            <ul class="pagination">
                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-controller="CheckoutHistory"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-filter="@Model.Filter"
                       aria-label="Previous">
                        Previous
                    </a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page @Model.CurrentPage of @Model.TotalPages</span>
                </li>
                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-controller="CheckoutHistory"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-filter="@Model.Filter"
                       aria-label="Next">
                        Next
                    </a>
                </li>
            </ul>
        </nav>
    }
}
