@model EquipmentTracker.Web.ViewModels.AvailabilityDashboardViewModel

<div id="dashboard-content">
@if (!Model.Categories.Any())
{
    <div class="alert alert-info">No equipment found matching the selected filters.</div>
}
else
{
    foreach (var cat in Model.Categories)
    {
        <div class="card mb-3 border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center bg-light py-3">
                <div>
                    <h2 class="h5 mb-0" style="font-size: 1.1rem; font-weight: 600;">@cat.Category</h2>
                    @if (!string.IsNullOrWhiteSpace(cat.SiteName))
                    {
                        <small class="text-muted">@cat.SiteName</small>
                    }
                </div>
                <span class="badge @(cat.AvailableCount > 0 ? "bg-success" : "bg-secondary") fs-6">
                    @cat.AvailableCount / @cat.TotalCount available
                </span>
                <!-- Notify Me on entire category -->
                <form method="post" action="/AvailabilityDashboard/SubscribeCategory" class="ms-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="category" value="@cat.Category" />
                    <input type="hidden" name="returnSite" value="@Model.SiteFilter" />
                    <input type="hidden" name="returnCategory" value="@Model.CategoryFilter" />
                    <button type="submit" class="btn btn-sm btn-outline-primary"
                            style="min-height: 44px; min-width: 44px; font-size: 1rem;"
                            title="Notify me when any @cat.Category becomes available">
                        🔔 Notify Me
                    </button>
                </form>
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var item in cat.Items)
                {
                    var statusClass = item.CompoundStatus switch
                    {
                        EquipmentTracker.Web.Models.EquipmentCompoundStatus.Available => "list-group-item-success",
                        EquipmentTracker.Web.Models.EquipmentCompoundStatus.CheckedOut => "list-group-item-warning",
                        EquipmentTracker.Web.Models.EquipmentCompoundStatus.UnderMaintenance => "list-group-item-danger",
                        EquipmentTracker.Web.Models.EquipmentCompoundStatus.SoftHeld => "list-group-item-info",
                        _ => ""
                    };
                    <li class="list-group-item @statusClass d-flex justify-content-between align-items-center py-3" style="font-size: 1.1rem;">
                        <div>
                            <span class="fw-semibold">@item.Name</span>
                            @if (!string.IsNullOrWhiteSpace(item.SiteName))
                            {
                                <span class="text-muted small ms-2">@item.SiteName</span>
                            }
                            @if (item.CompoundStatus != EquipmentTracker.Web.Models.EquipmentCompoundStatus.Available)
                            {
                                <span class="badge bg-secondary ms-2">@item.BlockingReason</span>
                            }
                            else
                            {
                                <span class="badge bg-success ms-2">Available</span>
                            }
                        </div>

                        <div class="d-flex gap-2">
                            @if (item.CompoundStatus == EquipmentTracker.Web.Models.EquipmentCompoundStatus.Available)
                            {
                                <!-- Place soft hold -->
                                <form method="post" action="/AvailabilityDashboard/PlaceHold">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="equipmentItemId" value="@item.ItemId" />
                                    <input type="hidden" name="returnSite" value="@Model.SiteFilter" />
                                    <input type="hidden" name="returnCategory" value="@Model.CategoryFilter" />
                                    <button type="submit" class="btn btn-sm btn-success"
                                            style="min-height: 44px; min-width: 44px; font-size: 1rem;">
                                        Hold 30min
                                    </button>
                                </form>
                            }
                            else if (item.CompoundStatus == EquipmentTracker.Web.Models.EquipmentCompoundStatus.SoftHeld && item.SoftHoldOwnerUserId.HasValue)
                            {
                                <!-- Release own hold -->
                                <form method="post" action="/AvailabilityDashboard/ReleaseHold">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="holdId" value="@item.ActiveSoftHoldId" />
                                    <input type="hidden" name="returnSite" value="@Model.SiteFilter" />
                                    <input type="hidden" name="returnCategory" value="@Model.CategoryFilter" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary"
                                            style="min-height: 44px; min-width: 44px; font-size: 1rem;">
                                        Release Hold
                                    </button>
                                </form>
                            }
                            else
                            {
                                <!-- Notify Me on unavailable item -->
                                <form method="post" action="/AvailabilityDashboard/SubscribeItem">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="equipmentItemId" value="@item.ItemId" />
                                    <input type="hidden" name="returnSite" value="@Model.SiteFilter" />
                                    <input type="hidden" name="returnCategory" value="@Model.CategoryFilter" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary"
                                            style="min-height: 44px; min-width: 44px; font-size: 1rem;">
                                        🔔 Notify Me
                                    </button>
                                </form>
                            }
                        </div>
                    </li>
                }
            </ul>
        </div>
    }
}
</div>
