@model EquipmentTracker.Web.ViewModels.FleetUtilizationViewModel
@using EquipmentTracker.Web.Services

@{
    ViewData["Title"] = "Fleet Utilization Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>⚙️ Fleet Utilization Dashboard</h2>
        @if (Model.CanExportCfoReport)
        {
            <a asp-controller="CfoReport" asp-action="GenerateReport"
               class="btn btn-primary" target="_blank">
                📊 Export CFO Report
            </a>
        }
        else
        {
            <button class="btn btn-secondary" disabled
                    title="Available to Admins and Finance roles only.">
                📊 Export CFO Report
            </button>
        }
    </div>

    <!-- Summary badges -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-danger text-center p-3">
                <h5 class="text-danger">🔴 Idle (&lt;40%)</h5>
                <h3>@Model.IdleCount</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-warning text-center p-3">
                <h5 class="text-warning">🟡 Monitor (40–70%)</h5>
                <h3>@Model.MonitorCount</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-success text-center p-3">
                <h5 class="text-success">🟢 Healthy (&gt;70%)</h5>
                <h3>@Model.HealthyCount</h3>
            </div>
        </div>
    </div>

    @if (!Model.Assets.Any())
    {
        <div class="alert alert-info" role="alert">
            No assets tracked yet — add equipment to begin tracking utilization.
        </div>
    }
    else
    {
        <p class="text-muted small">
            Assets ranked lowest to highest by trailing 3-month utilization.
            <span data-bs-toggle="tooltip"
                  title="Utilization % = Active Hours ÷ Available Hours. Active Hours = total time equipment was checked out. Available Hours = Calendar Hours − Scheduled Maintenance Hours.">
                ℹ️ Methodology
            </span>
        </p>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Asset</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Current Month</th>
                        <th>Trailing 3M</th>
                        <th>Trailing 12M</th>
                        <th>Trend</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var asset in Model.Assets)
                    {
                        var statusClass = asset.Status switch {
                            UtilizationStatus.Idle    => "table-danger",
                            UtilizationStatus.Monitor => "table-warning",
                            _                          => "table-success"
                        };
                        var statusBadge = asset.Status switch {
                            UtilizationStatus.Idle    => "🔴 Idle",
                            UtilizationStatus.Monitor => "🟡 Monitor",
                            _                          => "🟢 Healthy"
                        };
                        var trendIcon = asset.Trend switch {
                            UtilizationTrend.Up   => "⬆️",
                            UtilizationTrend.Down => "⬇️",
                            _                      => "➡️"
                        };
                        <tr class="@statusClass">
                            <td>@asset.AssetName</td>
                            <td>@asset.AssetCategory</td>
                            <td>@statusBadge</td>
                            <td>@asset.CurrentMonthRate.ToString("P0")</td>
                            <td>@asset.Trailing3MonthsRate.ToString("P0")</td>
                            <td>@asset.Trailing12MonthsRate.ToString("P0")</td>
                            <td>@trendIcon</td>
                            <td>
                                <a asp-controller="UtilizationDashboard"
                                   asp-action="Asset"
                                   asp-route-id="@asset.AssetId"
                                   class="btn btn-sm btn-outline-primary">Detail</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <a asp-controller="BuyRent" asp-action="Index" class="btn btn-outline-secondary">
                💡 View Buy vs. Rent Recommendations
            </a>
        </div>
    }
</div>
